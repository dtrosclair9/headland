# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (2026 key format — sb_publishable_* / sb_secret_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# psql connection string for migrations (Direct connection, port 5432)
SUPABASE_DB_URL=

# Mapbox (URL-restrict the public token to your production domain)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Sentinel Hub (NDVI)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
SENTINEL_HUB_INSTANCE_ID=

# Stripe (Phase 11 — leave blank until billing turns on)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
