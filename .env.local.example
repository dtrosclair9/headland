# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (2026 key format — sb_publishable_* / sb_secret_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# psql connection string for migrations (Direct connection, port 5432)
SUPABASE_DB_URL=

# Mapbox (URL-restrict the public token to your production domain)
NEXT_PUBLIC_MAPBOX_TOKEN=


# Stripe (Phase 11 — leave blank until billing turns on)
STRIPE_SECRET_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Local UI self-test account (scripts/ui-check.mjs) — values live only in .env.local
UI_TEST_EMAIL=
UI_TEST_PASSWORD=

# Ops (cron auth, signup emails, error monitoring)
CRON_SECRET=
RESEND_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
UI_CHECK_BASE=
